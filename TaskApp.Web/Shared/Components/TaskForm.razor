@using TaskApp.Web.Models
@namespace TaskApp.Web.Shared.Components

<EditForm Model="@taskModel" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />

    <div class="bg-white shadow-md rounded-2xl p-5 mb-6 border">

        <h3 class="text-lg font-semibold mb-4">Add New Task</h3>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

            <div>
                <InputText class="border rounded-lg p-2 w-full focus:outline-none focus:ring-2 focus:ring-blue-400"
                        @bind-Value="taskModel.Title"
                        placeholder="Task title" />

                <div class="min-h-[20px]">
                    <ValidationMessage For="@(() => taskModel.Title)" class="validation-message text-sm" />
                </div>
            </div>

            <div>
                <InputText class="border rounded-lg p-2 w-full focus:outline-none focus:ring-2 focus:ring-blue-400"
                        @bind-Value="taskModel.Description"
                        placeholder="Description" />

                <div class="min-h-[20px]">
                    <ValidationMessage For="@(() => taskModel.Description)" class="validation-message text-sm" />
                </div>
            </div>

            <div class="flex flex-col justify-end">
                <button type="submit"
                        class="bg-blue-600 text-white rounded-lg px-4 py-2 hover:bg-blue-700 transition w-full">
                    Add Task
                </button>
            </div>

        </div>

    </div>
</EditForm>

@code {
    [Parameter] public EventCallback<TaskItem> OnSubmit { get; set; }

    private TaskItem taskModel = new();

    private async Task HandleSubmit()
    {
        taskModel.CreatedAt = DateTime.UtcNow;

        await OnSubmit.InvokeAsync(taskModel);

        taskModel = new TaskItem();
    }
}