@namespace TaskApp.Web.Shared.Components

<div class="flex items-center justify-between bg-blue-50 shadow-sm rounded-xl p-4 mb-4 border">

    <span class="font-medium text-gray-700">Filter Tasks</span>

    <select class="border rounded-lg p-2 focus:outline-none focus:ring-2 focus:ring-blue-400"
            value="@Value"
            @onchange="OnValueChanged">
        <option value="All">All</option>
        <option value="Completed">Completed</option>
        <option value="Pending">Pending</option>
    </select>

</div>

@code {
    [Parameter] public string Value { get; set; } = "All";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    private async Task OnValueChanged(ChangeEventArgs e)
    {
        Value = e.Value?.ToString() ?? "All";
        await ValueChanged.InvokeAsync(Value);
    }
}